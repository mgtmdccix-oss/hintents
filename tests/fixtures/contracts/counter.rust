// Counter — minimal Soroban smart contract fixture used by the time-travel
// integration tests.
//
// This source is a reference artifact. The compiled WASM is not required at
// test time because the integration tests drive a MockRunner. A real end-to-end
// run would compile this with:
//
//   cargo build --target wasm32-unknown-unknown --release
//   soroban contract optimize --wasm target/wasm32-unknown-unknown/release/counter.wasm
//
// The contract exposes two entry points:
//
//   increment(env: Env) -> u32
//       Reads the current count from instance storage, adds 1, persists the new
//       value, and returns it.  Each call produces a diagnostic event that the
//       Rust host records with the WASM instruction offset of the store
//       instruction.  The time-travel tests step through these offsets to verify
//       that step indices align with trace instruction offsets.
//
//   get(env: Env) -> u32
//       Returns the current count without mutating state.

#![no_std]

use soroban_sdk::{contract, contractimpl, symbol_short, Env, Symbol};

const COUNT_KEY: Symbol = symbol_short!("COUNT");

#[contract]
pub struct Counter;

#[contractimpl]
impl Counter {
    /// Increment the counter by one and return the new value.
    pub fn increment(env: Env) -> u32 {
        let count: u32 = env
            .storage()
            .instance()
            .get(&COUNT_KEY)
            .unwrap_or(0);

        let new_count = count + 1;

        // The WASM store instruction here is the one whose offset the Rust host
        // records in the DiagnosticEvent's wasm_instruction field.
        env.storage().instance().set(&COUNT_KEY, &new_count);

        new_count
    }

    /// Return the current counter value without mutating state.
    pub fn get(env: Env) -> u32 {
        env.storage()
            .instance()
            .get(&COUNT_KEY)
            .unwrap_or(0)
    }
}

#[cfg(test)]
mod test {
    use super::*;
    use soroban_sdk::Env;

    #[test]
    fn test_increment_starts_at_one() {
        let env = Env::default();
        let contract_id = env.register_contract(None, Counter);
        let client = CounterClient::new(&env, &contract_id);
        assert_eq!(client.increment(), 1);
    }

    #[test]
    fn test_increment_is_cumulative() {
        let env = Env::default();
        let contract_id = env.register_contract(None, Counter);
        let client = CounterClient::new(&env, &contract_id);
        assert_eq!(client.increment(), 1);
        assert_eq!(client.increment(), 2);
        assert_eq!(client.increment(), 3);
    }

    #[test]
    fn test_get_returns_current_count() {
        let env = Env::default();
        let contract_id = env.register_contract(None, Counter);
        let client = CounterClient::new(&env, &contract_id);
        client.increment();
        client.increment();
        assert_eq!(client.get(), 2);
    }
}
